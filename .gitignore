# Сборка
/target/

# Транскрипты и состояние сессий (приватное содержимое диалогов)
.theseus/

# Логи и временные файлы
*.log
*.tmp

# ОС/редакторы
.DS_Store
*.swp
__pycache__/

# Секреты — страховка на будущее (в репо их нет: ключи только в env и в
# ~/.config/theseus/config.toml вне репозитория; «ключи» в src/*_tests —
# синтетические фикстуры сканера секретов)
.env
.env.*
!.env.example
*.pem
*.key
config.local.toml


# Локальные черновики анонсов (не для публикации)
/подробно_тесей*.txt
/коротко_тесей*.txt

# Одноразовые артефакты-скрипты анализа сессий
/check_*.py
/fetch_*.py
/parse_*.py
/gen_*.py

# Извлечённые из docx тексты и скачанные дайджесты в корне (рабочие файлы)
/docx_extracted/
/*_????-??-??.md

# Рабочие артефакты агента в корне (графы концептов, пробы записи)
/graph.json
/graph.md
/*_graph.json
/*_graph.md
/.test_write

# Сгенерированные агентом скрипты в корне (create_review.py и т.п.)
/create_*.py
